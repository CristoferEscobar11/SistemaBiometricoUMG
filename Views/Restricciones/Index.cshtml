@model List<SistemaBiometricoUMG.Models.Restriccion>
@{
    ViewData["Title"] = "Restricciones de Ingreso";
}

<div class="container mt-4">

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">@TempData["Exito"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow">
        <div class="card-header text-white py-3 d-flex
            justify-content-between align-items-center"
             style="background-color:#8B0000;">
            <div>
                <h3 class="mb-0">🚫 Restricciones de Ingreso</h3>
                <small>Personas con acceso restringido a las instalaciones</small>
            </div>
            <a href="/Restricciones/Agregar" class="btn btn-light">
                ➕ Agregar Restricción
            </a>
        </div>
        <div class="card-body">

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">
                    ✅ No hay personas con restricción de ingreso actualmente.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Foto</th>
                                <th>Nombre</th>
                                <th>Correo</th>
                                <th>Tipo</th>
                                <th>Motivo</th>
                                <th>Fecha</th>
                                <th>Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model)
                            {
                                <tr class="table-danger">
                                    <td>
                                        @if (!string.IsNullOrEmpty(r.Persona?.FotoRuta))
                                        {
                                            <img src="@r.Persona.FotoRuta"
                                                 width="50" height="50"
                                                 class="rounded-circle"
                                                 style="object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <span>Sin foto</span>
                                        }
                                    </td>
                                    <td>
                                        <strong>
                                            @r.Persona?.Nombre @r.Persona?.Apellido
                                        </strong>
                                    </td>
                                    <td>@r.Persona?.Correo</td>
                                    <td>@r.Persona?.TipoPersona</td>
                                    <td>
                                        <span class="badge bg-danger">
                                            @r.Motivo
                                        </span>
                                    </td>
                                    <td>
                                        @r.FechaRegistro.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td>
                                        <form method="post"
                                              action="/Restricciones/Quitar"
                                              onsubmit="return confirm(
                                            '¿Quitar esta restricción?')">
                                            <input type="hidden"
                                                   name="id" value="@r.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-success">
                                                ✅ Quitar Restricción
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>