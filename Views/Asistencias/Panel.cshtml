@model SistemaBiometricoUMG.Models.AsistenciaPanelViewModel
@{
    ViewData["Title"] = "Panel de Asistencia";
}

<div class="container mt-4">

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success">@TempData["Exito"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card shadow">
        <div class="card-header text-white text-center py-3"
             style="background-color:#003366;">
            <h3>🌳 Panel de Asistencia</h3>
            <p class="mb-0">@Model.Fecha.ToString("dddd, dd MMMM yyyy")</p>
        </div>
        <div class="card-body">

            <!-- Selector de salón -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label fw-bold">Seleccionar Salón:</label>
                    <select class="form-select" onchange="cambiarSalon(this.value)">
                        @foreach (var u in Model.Ubicaciones)
                        {
                            if (u.Id == Model.UbicacionSeleccionada)
                            {
                                <option value="@u.Id" selected>@u.Nombre</option>
                            }
                            else
                            {
                                <option value="@u.Id">@u.Nombre</option>
                            }
                        }
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    @if (!Model.YaConfirmado)
                    {
                        <form method="post" action="/Asistencias/Confirmar"
                              onsubmit="return confirm(
                              '¿Está seguro de confirmar la asistencia?')">
                            <input type="hidden" name="ubicacionId"
                                   value="@Model.UbicacionSeleccionada" />
                     
                            <input type="hidden" name="catedraticoid" value="10" />
                            <button type="submit" class="btn btn-success btn-lg">
                                ✅ Confirmar Asistencia del Curso
                            </button>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            ✅ Asistencia ya confirmada hoy
                        </div>
                    }
                </div>
            </div>

            <!-- Árbol de asistencia -->
            <h5 class="mb-3">👥 Estudiantes</h5>
            <div class="row">
                @foreach (var estudiante in Model.Estudiantes)
                {
                    bool presente = Model.PersonasPresentes
                                        .Contains(estudiante.Id);
                    <div class="col-md-3 mb-3">
                        <div class="card text-center shadow-sm"
                             style="border: 3px solid @(presente ? 
                             "#28a745" : "#dc3545");">
                            <div class="card-body p-2"
                                 style="background-color: @(presente ? 
                                 "#d4edda" : "#f8d7da");">
                                @if (!string.IsNullOrEmpty(estudiante.FotoRuta))
                                {
                                    <img src="@estudiante.FotoRuta"
                                         class="rounded-circle mb-2"
                                         width="70" height="70"
                                         style="object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="rounded-circle bg-secondary 
                                                d-inline-flex align-items-center 
                                                justify-content-center mb-2"
                                         style="width:70px;height:70px;">
                                        <span class="text-white fs-4">
                                            @estudiante.Nombre[0]
                                        </span>
                                    </div>
                                }
                                <p class="fw-bold mb-0 small">
                                    @estudiante.Nombre @estudiante.Apellido
                                </p>
                                <p class="mb-0" style="font-size:11px;">
                                    @estudiante.Correo
                                </p>
                                <span class="badge @(presente ? 
                                      "bg-success" : "bg-danger") mt-1">
                                    @(presente ? "✅ Presente" : "❌ Ausente")
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Resumen -->
            <hr />
            <div class="row text-center mt-2">
                <div class="col-4">
                    <div class="card bg-success text-white p-3">
                        <h4>@Model.PersonasPresentes.Count</h4>
                        <p class="mb-0">Presentes</p>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card bg-danger text-white p-3">
                        <h4>
                            @(Model.Estudiantes.Count - 
                              Model.PersonasPresentes.Count)
                        </h4>
                        <p class="mb-0">Ausentes</p>
                    </div>
                </div>
                <div class="col-4">
                    <div class="card bg-primary text-white p-3">
                        <h4>@Model.Estudiantes.Count</h4>
                        <p class="mb-0">Total</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function cambiarSalon(id) {
        window.location.href = '/Asistencias/Panel?ubicacionId=' + id;
    }
</script>
}